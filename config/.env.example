# Contextual Agent - Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# ============================================
# EXTERNAL API KEYS
# ============================================

# OpenWeatherMap API
# Sign up at: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here

# NewsAPI
# Sign up at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Zipcodebase API (or alternative geocoding service)
# Sign up at: https://zipcodebase.com/
GEOCODING_API_KEY=your_geocoding_api_key_here

# Optional: Eventbrite API for local events
# Sign up at: https://www.eventbrite.com/platform/
EVENTBRITE_TOKEN=your_eventbrite_token_here

# ============================================
# APPLICATION CONFIGURATION
# ============================================

# Server Configuration
PORT=8080
HOST=0.0.0.0

# Environment (development, production, testing)
ENVIRONMENT=development

# Debug Mode (True for development, False for production)
DEBUG=True

# ============================================
# CACHING CONFIGURATION
# ============================================

# Cache timeout in seconds
CACHE_WEATHER_TIMEOUT=3600        # 1 hour
CACHE_NEWS_TIMEOUT=1800           # 30 minutes
CACHE_GEOCODING_TIMEOUT=86400     # 24 hours (geocoding rarely changes)

# Enable/disable caching
ENABLE_CACHE=True

# ============================================
# RATE LIMITING
# ============================================

# Maximum requests per minute per IP
RATE_LIMIT_PER_MINUTE=30

# ============================================
# LOGGING
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path (leave empty for console only)
LOG_FILE=

# ============================================
# CORS SETTINGS
# ============================================

# Allowed origins (comma-separated, or * for all)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ============================================
# DATA SOURCE PREFERENCES
# ============================================

# Enable/disable specific data sources
ENABLE_WEATHER=True
ENABLE_NEWS=True
ENABLE_EVENTS=True

# News search parameters
NEWS_MAX_RESULTS=20
NEWS_LANGUAGE=en

# Weather units (metric, imperial, standard)
WEATHER_UNITS=imperial
